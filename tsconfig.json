{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "jsx": "preserve",
    "importHelpers": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["components/*"],
      "@/utils/*": ["utils/*"],
      "@/store/*": ["store/*"],
      "@/api/*": ["api/*"],
      "@/types/*": ["types/*"]
    },
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["@dcloudio/types"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.vue"],
  "exclude": ["node_modules", "unpackage", "dist"]
}
